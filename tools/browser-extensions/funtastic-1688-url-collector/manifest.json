{
  "manifest_version": 3,
  "name": "Funtastic 1688 URL Collector",
  "description": "발주 엑셀 주문번호로 1688 구매 URL과 상세페이지용 상품 이미지를 수집합니다.",
  "version": "1.3.1",
  "permissions": [
    "alarms",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.1688.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "1688 URL 수집"
  },
  "content_scripts": [
    {
      "matches": [
        "https://funtastic-saas-vercel.vercel.app/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "js": ["saas-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.1688.com/*"],
      "js": ["1688-page-capture.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "world": "MAIN"
    },
    {
      "matches": ["https://*.1688.com/*"],
      "js": ["1688-collector.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    },
    {
      "matches": ["https://detail.1688.com/offer/*"],
      "js": ["1688-url-verifier.js"],
      "run_at": "document_idle"
    }
  ]
}
