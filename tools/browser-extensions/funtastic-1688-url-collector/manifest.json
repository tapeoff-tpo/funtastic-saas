{
  "manifest_version": 3,
  "name": "Funtastic 1688 URL Collector",
  "description": "Funtastic SaaS 발주 주문번호로 1688 구매 URL을 수집합니다.",
  "version": "1.0.0",
  "permissions": [
    "alarms",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.1688.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "1688 URL 수집"
  },
  "content_scripts": [
    {
      "matches": [
        "https://funtastic-saas-vercel.vercel.app/*",
        "http://localhost:3000/*"
      ],
      "js": ["saas-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://*.1688.com/*"],
      "js": ["1688-collector.js"],
      "run_at": "document_idle"
    }
  ]
}
