{
  "manifest_version": 3,
  "name": "Funtastic Coupang Sourcing Capture",
  "description": "Capture Coupang sourcing products and search 1688 candidates for Funtastic SaaS.",
  "version": "0.2.0",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://www.coupang.com/*",
    "https://*.coupang.com/*",
    "https://*.1688.com/*",
    "https://funtastic-saas-vercel.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Funtastic Sourcing Capture"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.coupang.com/*",
        "https://*.coupang.com/*"
      ],
      "js": [
        "coupang-capture.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.1688.com/*"
      ],
      "js": [
        "1688-sourcing-search.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    },
    {
      "matches": [
        "https://funtastic-saas-vercel.vercel.app/*",
        "http://localhost:3000/*"
      ],
      "js": [
        "saas-bridge.js"
      ],
      "run_at": "document_start"
    }
  ]
}
